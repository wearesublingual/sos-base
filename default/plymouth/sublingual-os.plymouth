[Plymouth Theme]
Name=Sublingual OS
Description=Sublingual OS splash screen.
ModuleName=script

[script]
ImageDir=/usr/share/plymouth/themes/sublingual-os
ScriptFile=/usr/share/plymouth/themes/sublingual-os/sublingual-os.script
ConsoleLogBackgroundColor=0x1a1b26
MonospaceFont=Cantarell 11
Font=Cantarell 11
