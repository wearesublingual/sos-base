# Changes require a restart to take effect.

# Ensure Sublingual OS bins are in the path
export SUBLINGUAL_OS_PATH=$HOME/.local/share/sublingual-os
export PATH=$SUBLINGUAL_OS_PATH/bin:$PATH:$HOME/.local/bin

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
sublingual-os-cmd-present mise && eval "$(mise activate bash --shims)"
