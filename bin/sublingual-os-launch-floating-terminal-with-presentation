#!/bin/bash

# Launch a floating terminal with the Omarchy logo presentation, then execute the command passed in, and finally end with the sublingual-os-show-done presentation.
# Used by actions such as Update System.

cmd="$*"
exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.sublingual-os.terminal --title=Omarchy -e bash -c "sublingual-os-show-logo; $cmd; if (( \$? != 130 )); then sublingual-os-show-done; fi"
