#!/bin/bash

set -e

# Run the update inside a PTY so pacman/yay keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $SUBLINGUAL_OS_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env SUBLINGUAL_OS_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/sublingual-os-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, get help from the community at https://omarchy.org/discord\033[0m"' ERR

if [[ $1 == "-y" ]] || sublingual-os-update-confirm; then
  sublingual-os-snapshot create || (($? == 127))
  sublingual-os-update-git
  sublingual-os-update-perform
fi
