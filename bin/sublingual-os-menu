#!/bin/bash

# Launch the Sublingual OS Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/sublingual-os/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | sublingual-os-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptвҖҰ" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.sublingual-os.terminal "$@"
}

present_terminal() {
  sublingual-os-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  sublingual-os-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; sublingual-os-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; sublingual-os-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; sublingual-os-pkg-add $2 && sleep 2 && sublingual-os-font-set '$3'"
}

install_terminal() {
  present_terminal "sublingual-os-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; sublingual-os-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; sublingual-os-pkg-aur-add $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "п„ң  Keybindings\nпҗ…  Sublingual OS\nпҚҷ  Hyprland\nу°ЈҮ  Arch\nоҡ®  Neovim\nуұҶғ  Bash") in
  *Keybindings*) sublingual-os-menu-keybindings ;;
  *Omarchy*) omarchy-launch-webapp "https://learn.omacom.io/2/the-omarchy-manual" ;;
  *Hyprland*) sublingual-os-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) sublingual-os-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) sublingual-os-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) sublingual-os-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "пҖ°  Capture\nп”Һ  Share\nу°”Һ  Toggle\nоҪ°  Hardware") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "пҖ°  Screenshot\nпҖҪ  Screenrecord\nу°ғү  Color") in
  *Screenshot*) sublingual-os-cmd-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  sublingual-os-cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "пҖҪ  With no audio\nпҖҪ  With desktop audio\nпҖҪ  With desktop + microphone audio\nпҖҪ  With desktop + microphone audio + webcam") in
  *"With no audio") sublingual-os-cmd-screenrecord ;;
  *"With desktop audio") sublingual-os-cmd-screenrecord --with-desktop-audio ;;
  *"With desktop + microphone audio") sublingual-os-cmd-screenrecord --with-desktop-audio --with-microphone-audio ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    sublingual-os-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "пҒҝ  Clipboard\nо©»  File \nп„”  Folder") in
  *Clipboard*) sublingual-os-cmd-share clipboard ;;
  *File*) terminal bash -c "sublingual-os-cmd-share file" ;;
  *Folder*) terminal bash -c "sublingual-os-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "уұ„„  Screensaver\nу°”Һ  Nightlight\nуұ«–  Idle Lock\nу°Қң  Top Bar\nуұӮ¬  Workspace Layout\nоҳӘ  Window Gaps\nпӢҗ  1-Window Ratio\nу°Қ№  Monitor Scaling\nу°ӣ§  Laptop Display") in

  *Screensaver*) sublingual-os-toggle-screensaver ;;
  *Nightlight*) sublingual-os-toggle-nightlight ;;
  *Idle*) sublingual-os-toggle-idle ;;
  *Bar*) sublingual-os-toggle-waybar ;;
  *Layout*) sublingual-os-hyprland-workspace-layout-toggle ;;
  *Ratio*) sublingual-os-hyprland-window-single-square-aspect-toggle ;;
  *Gaps*) sublingual-os-hyprland-window-gaps-toggle ;;
  *Scaling*) sublingual-os-hyprland-monitor-scaling-cycle ;;
  *Laptop*) sublingual-os-hyprland-monitor-internal-toggle ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  case $(menu "Toggle" "о°ҷ  Hybrid GPU") in
  *"Hybrid GPU"*) present_terminal sublingual-os-toggle-hybrid-gpu ;;
  *) show_trigger_menu ;;
  esac
}

show_style_menu() {
  case $(menu "Style" "у°ёҢ  Theme\nоҷҷ  Font\nпҖҫ  Background\nпҚҷ  Hyprland\nуұ„„  Screensaver\nо©ҙ  About") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *Screensaver*) open_in_editor ~/.config/sublingual-os/branding/screensaver.txt ;;
  *About*) open_in_editor ~/.config/sublingual-os/branding/about.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  sublingual-os-launch-walker -m menus:sublingualOsThemes --width 800 --minheight 400
}

show_background_menu() {
  sublingual-os-launch-walker -m menus:sublingualOsBackgroundSelector --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(sublingual-os-font-list)" "--width 350" "$(sublingual-os-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    sublingual-os-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="оҳё  Audio\nпҮ«  Wifi\nу°ӮҜ  Bluetooth\nуұҗӢ  Power Profile\nпҖ‘  System Sleep\nу°Қ№  Monitors"
  [[ -f ~/.config/hypr/bindings.conf ]] && options="$options\nп„ң  Keybindings"
  [[ -f ~/.config/hypr/input.conf ]] && options="$options\nоҫә  Input"
  options="$options\nу°ұ”  DNS\nо¬‘  Security\nоҳ•  Config"

  case $(menu "Setup" "$options") in
  *Audio*) sublingual-os-launch-audio ;;
  *Wifi*) sublingual-os-launch-wifi ;;
  *Bluetooth*) sublingual-os-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Monitors*) open_in_editor ~/.config/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/hypr/bindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *DNS*) present_terminal sublingual-os-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(sublingual-os-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ $profile == "CNCLD" || -z $profile ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_security_menu() {
  case $(menu "Setup" "у°Ҳ·  Fingerprint\nо¬‘  Fido2") in
  *Fingerprint*) present_terminal sublingual-os-setup-fingerprint ;;
  *Fido2*) present_terminal sublingual-os-setup-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "п’ү  Defaults\nпҚҷ  Hyprland\nпҚҷ  Hypridle\nпҚҷ  Hyprlock\nпҚҷ  Hyprsunset\nпҚқ  Swayosd\nу°Ң§  Walker\nу°Қң  Waybar\nу°һ…  XCompose") in
  *Defaults*) open_in_editor ~/.config/uwsm/default ;;
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && sublingual-os-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && sublingual-os-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && sublingual-os-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && sublingual-os-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && sublingual-os-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && sublingual-os-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

  if [[ -f ~/.local/state/sublingual-os/toggles/suspend-off ]]; then
    options="$optionsу°’І  Enable Suspend"
  else
    options="$optionsу°’І  Disable Suspend"
  fi

  if sublingual-os-hibernation-available; then
    options="$options\nу°ӨҒ  Disable Hibernate"
  else
    options="$options\nу°ӨҒ  Enable Hibernate"
  fi

  case $(menu "System" "$options") in
  *Suspend*) sublingual-os-toggle-suspend ;;
  *"Enable Hibernate"*) present_terminal sublingual-os-hibernation-setup ;;
  *"Disable Hibernate"*) present_terminal sublingual-os-hibernation-remove ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "у°ЈҮ  Package\nу°ЈҮ  AUR\nпүЁ  Web App\nп’ү  TUI\nп’Ү  Service\nоҜҸ  Style\nу°ө®  Development\nп…ң  Editor\nп’ү  Terminal\nуұҡӨ  AI\nу°ҚІ  Windows\nп„ӣ  Gaming") in
  *Package*) terminal sublingual-os-pkg-install ;;
  *AUR*) terminal sublingual-os-pkg-aur-install ;;
  *Web*) present_terminal sublingual-os-webapp-install ;;
  *TUI*) present_terminal sublingual-os-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) present_terminal "sublingual-os-windows-vm install" ;;
  *Gaming*) show_install_gaming_menu ;;
  *) show_main_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "оңҮ  Dropbox\nп’Ү  Tailscale\nуұҮұ  NordVPN [AUR]\nу°Ҹ–  ONCE\nу°ҹө  Bitwarden\nоҹ°  Chromium Account") in
  *Dropbox*) present_terminal sublingual-os-install-dropbox ;;
  *Tailscale*) present_terminal sublingual-os-install-tailscale ;;
  *NordVPN*) present_terminal sublingual-os-install-nordvpn ;;
  *ONCE*) present_terminal sublingual-os-install-once ;;
  *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
  *Chromium*) present_terminal sublingual-os-install-chromium-google-account ;;
  *) show_install_menu ;;
  esac
}

show_install_editor_menu() {
  case $(menu "Install" "оЈҡ  VSCode\nп…ң  Cursor\nп…ң  Zed\nп…ң  Sublime Text\nп…ң  Helix\nп…ң  Emacs") in
  *VSCode*) present_terminal sublingual-os-install-vscode ;;
  *Cursor*) install_and_launch "Cursor" "cursor-bin" "cursor" ;;
  *Zed*) install_and_launch "Zed" "zed" "dev.zed.Zed" ;;
  *Sublime*) install_and_launch "Sublime Text" "sublime-text-4" "sublime_text" ;;
  *Helix*) install "Helix" "helix" ;;
  *Emacs*) install "Emacs" "emacs-wayland" && systemctl --user enable --now emacs.service ;;
  *) show_install_menu ;;
  esac
}

show_install_terminal_menu() {
  case $(menu "Install" "п’ү  Alacritty\nп’ү  Ghostty\nп’ү  Kitty") in
  *Alacritty*) install_terminal "alacritty" ;;
  *Ghostty*) install_terminal "ghostty" ;;
  *Kitty*) install_terminal "kitty" ;;
  *) show_install_menu ;;
  esac
}

show_install_ai_menu() {
  ollama_pkg=$(
    (command -v nvidia-smi &>/dev/null && echo ollama-cuda) ||
      (command -v rocminfo &>/dev/null && echo ollama-rocm) ||
      echo ollama
  )

  case $(menu "Install" "о°’  Dictation\nуұҡӨ  LM Studio\nуұҡӨ  Ollama\nуұҡӨ  Crush") in
  *Dictation*) present_terminal sublingual-os-voxtype-install ;;
  *Studio*) install "LM Studio" "lmstudio-bin" ;;
  *Ollama*) install "Ollama" $ollama_pkg ;;
  *Crush*) install "Crush" "crush-bin" ;;
  *) show_install_menu ;;
  esac
}

show_install_gaming_menu() {
  case $(menu "Install" "пҶ¶  Steam\nу°ў№  NVIDIA GeForce NOW\nп„ӣ  RetroArch [AUR]\nу°Қі  Minecraft\nу°–ә  Xbox Controller [AUR]") in
  *Steam*) present_terminal sublingual-os-install-steam ;;
  *GeForce*) present_terminal sublingual-os-install-geforce-now ;;
  *RetroArch*) aur_install_and_launch "RetroArch" "retroarch retroarch-assets libretro libretro-fbneo" "com.libretro.RetroArch.desktop" ;;
  *Minecraft*) install_and_launch "Minecraft" "minecraft-launcher" "minecraft-launcher" ;;
  *Xbox*) present_terminal sublingual-os-install-xbox-controllers ;;
  *) show_install_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "у°ёҢ  Theme\nпҖҫ  Background\nоҷҷ  Font") in
  *Theme*) present_terminal sublingual-os-theme-install ;;
  *Background*) sublingual-os-theme-bg-install ;;
  *Font*) show_install_font_menu ;;
  *) show_install_menu ;;
  esac
}

show_install_font_menu() {
  case $(menu "Install" "оҷҷ  Cascadia Mono\nоҷҷ  Meslo LG Mono\nоҷҷ  Fira Code\nоҷҷ  Victor Code\nоҷҷ  Bistream Vera Mono\nоҷҷ  Iosevka" "--width 350") in
  *Cascadia*) install_font "Cascadia Mono" "ttf-cascadia-mono-nerd" "CaskaydiaMono Nerd Font" ;;
  *Meslo*) install_font "Meslo LG Mono" "ttf-meslo-nerd" "MesloLGL Nerd Font" ;;
  *Fira*) install_font "Fira Code" "ttf-firacode-nerd" "FiraCode Nerd Font" ;;
  *Victor*) install_font "Victor Code" "ttf-victor-mono-nerd" "VictorMono Nerd Font" ;;
  *Bistream*) install_font "Bistream Vera Code" "ttf-bitstream-vera-mono-nerd" "BitstromWera Nerd Font" ;;
  *Iosevka*) install_font "Iosevka" "ttf-iosevka-nerd" "Iosevka Nerd Font Mono" ;;
  *) show_install_menu ;;
  esac
}

