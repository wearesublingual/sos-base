}

show_update_menu() {
  case $(menu "Update" "оӨҖвҖү Sublingual OS\nу°”«  Channel\nоҳ•  Config\nу°ёҢ  Extra Themes\nо®ў  Process\nу°Ү…  Hardware\nо©ё  Firmware\nо¬‘  Password\nо¬Ғ  Timezone\nоҺғ  Time") in
  *Sublingual OS*) present_terminal sublingual-os-update ;;
  *Channel*) show_update_channel_menu ;;
  *Config*) show_update_config_menu ;;
  *Themes*) present_terminal sublingual-os-theme-update ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Firmware*) present_terminal sublingual-os-update-firmware ;;
  *Timezone*) present_terminal sublingual-os-tz-select ;;
  *Time*) present_terminal sublingual-os-update-time ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

show_update_channel_menu() {
  case $(menu "Update channel" "рҹҹў Stable\nрҹҹЎ RC\nрҹҹ  Edge\nрҹ”ҙ Dev") in
  *Stable*) present_terminal "sublingual-os-channel-set stable" ;;
  *RC*) present_terminal "sublingual-os-channel-set rc" ;;
  *Edge*) present_terminal "sublingual-os-channel-set edge" ;;
  *Dev*) present_terminal "sublingual-os-channel-set dev" ;;
  *) show_update_menu ;;
  esac
}
show_update_process_menu() {
  case $(menu "Restart" "пҚҷ  Hypridle\nпҚҷ  Hyprsunset\nпҚқ  Swayosd\nу°Ң§  Walker\nу°Қң  Waybar") in
  *Hypridle*) sublingual-os-restart-hypridle ;;
  *Hyprsunset*) sublingual-os-restart-hyprsunset ;;
  *Swayosd*) sublingual-os-restart-swayosd ;;
  *Walker*) sublingual-os-restart-walker ;;
  *Waybar*) sublingual-os-restart-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "пҚҷ  Hyprland\nпҚҷ  Hypridle\nпҚҷ  Hyprlock\nпҚҷ  Hyprsunset\nуұЈҙ  Plymouth\nпҚқ  Swayosd\nп’ү  Tmux\nу°Ң§  Walker\nу°Қң  Waybar") in
  *Hyprland*) present_terminal sublingual-os-refresh-hyprland ;;
  *Hypridle*) present_terminal sublingual-os-refresh-hypridle ;;
  *Hyprlock*) present_terminal sublingual-os-refresh-hyprlock ;;
  *Hyprsunset*) present_terminal sublingual-os-refresh-hyprsunset ;;
  *Plymouth*) present_terminal sublingual-os-refresh-plymouth ;;
  *Swayosd*) present_terminal sublingual-os-refresh-swayosd ;;
  *Tmux*) present_terminal sublingual-os-refresh-tmux ;;
  *Walker*) present_terminal sublingual-os-refresh-walker ;;
  *Waybar*) present_terminal sublingual-os-refresh-waybar ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "оҳё  Audio\nуұҡҫ  Wi-Fi\nу°ӮҜ  Bluetooth\nу°ҹё  Trackpad") in
  *Audio*) present_terminal sublingual-os-restart-pipewire ;;
  *Wi-Fi*) present_terminal sublingual-os-restart-wifi ;;
  *Bluetooth*) present_terminal sublingual-os-restart-bluetooth ;;
  *Trackpad*) present_terminal sublingual-os-restart-trackpad ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "о¬‘  Drive Encryption\nо¬‘  User") in
  *Drive*) present_terminal sublingual-os-drive-set-password ;;
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  sublingual-os-launch-about
}

show_system_menu() {
  local options="уұ„„  Screensaver\nпҖЈ  Lock"
  [[ ! -f ~/.local/state/sublingual-os/toggles/suspend-off ]] && options="$options\nу°’І  Suspend"
  sublingual-os-hibernation-available && options="$options\nу°ӨҒ  Hibernate"
  options="$options\nу°Қғ  Logout\nу°ңү  Restart\nу°җҘ  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) sublingual-os-launch-screensaver force ;;
  *Lock*) sublingual-os-lock-screen ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) sublingual-os-system-logout ;;
  *Restart*) sublingual-os-system-reboot ;;
  *Shutdown*) sublingual-os-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "у°Җ»  Apps\nу°§‘  Learn\nуұ“һ  Trigger\nоҜҸ  Style\nоҳ•  Setup\nу°үү  Install\nу°ӯҢ  Remove\nпҖЎ  Update\nо©ҙ  About\nпҖ‘  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "LaunchвҖҰ" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *share*) show_share_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/sublingual-os/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n $1 ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
