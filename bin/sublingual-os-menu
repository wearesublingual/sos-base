  case $(menu "Remove" "у°ЈҮ  Package\nпүЁ  Web App\nп’ү  TUI\nу°ө®  Development\nу°Ҹ“  Preinstalls\nо°’  Dictation\nу°ёҢ  Theme\nу°ҚІ  Windows\nу°Ҳ·  Fingerprint\nо¬‘  Fido2") in
