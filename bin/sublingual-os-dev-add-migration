#!/bin/bash

# Creates a new Sublingual OS migration named after the unix timestamp of the last commit.
# Only intended for Sublingual OS developers.

cd ~/.local/share/sublingual-os
migration_file="$HOME/.local/share/sublingual-os/migrations/$(git log -1 --format=%cd --date=unix).sh"
touch $migration_file

if [[ $1 != "--no-edit" ]]; then
  nvim $migration_file
fi

echo $migration_file
