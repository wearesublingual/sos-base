#!/bin/bash

set -e

echo -e "\e[32mUpdate Sublingual OS\e[0m"

sublingual-os-update-time

# Suppress Hyprland config errors while git updates default config files mid-pull
hyprctl keyword debug:suppress_errors true &>/dev/null || true

git -C $SUBLINGUAL_OS_PATH pull --autostash
git -C $SUBLINGUAL_OS_PATH --no-pager diff --check || git -C $SUBLINGUAL_OS_PATH reset --merge

hyprctl reload &>/dev/null || true
