#!/bin/bash
set -e

# Reinstall all default Sublingual OS packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
sublingual-os-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$SUBLINGUAL_OS_PATH/install/sublingual-os-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
