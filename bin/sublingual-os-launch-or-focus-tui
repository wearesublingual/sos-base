#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like sublingual-os-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.sublingual-os.$(basename "$1")"
LAUNCH_COMMAND="sublingual-os-launch-tui $@"

exec sublingual-os-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
