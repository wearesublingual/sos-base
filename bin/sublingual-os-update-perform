#!/bin/bash

set -e

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch tagwindow +noidle &>/dev/null || true

# Perform all update steps
sublingual-os-update-keyring
sublingual-os-update-available-reset
sublingual-os-update-system-pkgs
sublingual-os-migrate
sublingual-os-update-aur-pkgs
sublingual-os-update-orphan-pkgs
sublingual-os-hook post-update

sublingual-os-update-analyze-logs

sublingual-os-update-restart

# Re-enable screensaver/sleep after updates
hyprctl dispatch tagwindow -- -noidle &>/dev/null || true
