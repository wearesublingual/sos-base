#!/bin/bash

# Overwrite the user config for the Plymouth drive decryption and boot sequence with the Sublingual OS default and rebuild it.

sudo cp ~/.local/share/sublingual-os/default/plymouth/* /usr/share/plymouth/themes/sublingual-os/
sudo plymouth-set-default-theme sublingual-os

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
