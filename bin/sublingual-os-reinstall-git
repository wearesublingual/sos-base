#!/bin/bash
set -e

# Reinstall the Sublingual OS configuration directory from the git source.

git clone --depth=1 "https://github.com/basecamp/omarchy.git" ~/.local/share/sublingual-os-new >/dev/null
mv $SUBLINGUAL_OS_PATH ~/.local/share/sublingual-os-old
mv ~/.local/share/sublingual-os-new $SUBLINGUAL_OS_PATH
