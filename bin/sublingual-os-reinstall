#!/bin/bash
set -e

# Attempt to reinstall all default Sublingual OS packages and reset all the default configs.

echo -e "This will reinstall all the default Sublingual OS packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  sublingual-os-reinstall-git
  sublingual-os-reinstall-pkgs
  sublingual-os-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && sublingual-os-system-reboot
fi
